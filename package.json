{
  "name": "jslite",
  "version": "0.1.0",
  "description": "Sandboxed, subset JavaScript runtime for Node services.",
  "main": "index.js",
  "types": "jslite.d.ts",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "build": "napi build --platform --manifest-path crates/jslite-node/Cargo.toml --js-package-name jslite --output-dir . --no-js",
    "test": "npm run build && node --test tests/node/**/*.test.js && npm run test:types",
    "test:node": "node --test tests/node/**/*.test.js",
    "test:types": "tsc --noEmit -p tsconfig.typecheck.json",
    "test:rust": "cargo test --workspace",
    "lint": "cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keppoai/jslite.git"
  },
  "keywords": [
    "javascript",
    "runtime",
    "sandbox",
    "napi",
    "vm"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@napi-rs/cli": "^3.3.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  },
  "bugs": {
    "url": "https://github.com/keppoai/jslite/issues"
  },
  "homepage": "https://github.com/keppoai/jslite#readme"
}
