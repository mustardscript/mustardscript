{
  "name": "@keppoai/jslite",
  "version": "0.1.0",
  "description": "Sandboxed, subset JavaScript runtime for Node services.",
  "main": "index.js",
  "types": "jslite.d.ts",
  "files": [
    "Cargo.toml",
    "install.js",
    "index.js",
    "lib",
    "index.d.ts",
    "jslite.d.ts",
    "native-loader.js",
    "crates/jslite/Cargo.toml",
    "crates/jslite/src/**",
    "crates/jslite-bridge/Cargo.toml",
    "crates/jslite-bridge/src/**",
    "crates/jslite-node/Cargo.toml",
    "crates/jslite-node/build.rs",
    "crates/jslite-node/src/**",
    "crates/jslite-sidecar/Cargo.toml",
    "crates/jslite-sidecar/src/**"
  ],
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "napi": {
    "binaryName": "index",
    "packageName": "@keppoai/jslite",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "install": "node install.js",
    "build": "napi build --platform --manifest-path crates/jslite-node/Cargo.toml --js-package-name @keppoai/jslite --output-dir . --no-js",
    "ralph-loop": "node scripts/ralph-loop.js",
    "test": "npm run build && node --test tests/node/**/*.test.js && npm run test:types && npm run test:package-smoke",
    "test:conformance": "npm run test:differential && npm run test:test262",
    "test:differential": "node --test tests/node/differential.test.js tests/node/ast-conformance.test.js tests/node/property-differential.test.js tests/node/coverage-audit.test.js",
    "test:node": "node --test tests/node/**/*.test.js",
    "test:use-cases": "node scripts/audit-use-cases.js",
    "test:package-smoke": "node --test tests/package-smoke.test.js",
    "test:test262": "node --test tests/test262/**/*.test.js",
    "test:types": "tsc --noEmit -p tsconfig.typecheck.json",
    "test:rust": "cargo test --workspace",
    "test:hardening": "scripts/run-hardening.sh",
    "seed:fuzz-corpus": "node scripts/seed-fuzz-corpus.js",
    "bench:smoke": "npm run build && node --expose-gc benchmarks/smoke.js",
    "prebuilt:dirs": "napi create-npm-dirs",
    "prebuilt:artifacts": "napi artifacts --output-dir artifacts",
    "verify:prebuilt": "node scripts/verify-prebuilt.js",
    "verify:release": "node scripts/release-verify.js",
    "lint": "cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keppoai/jslite.git"
  },
  "keywords": [
    "javascript",
    "runtime",
    "sandbox",
    "napi",
    "vm"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@napi-rs/cli": "^3.3.0",
    "@types/node": "^25.6.0",
    "fast-check": "^4.6.0",
    "typescript": "^6.0.2"
  },
  "bugs": {
    "url": "https://github.com/keppoai/jslite/issues"
  },
  "homepage": "https://github.com/keppoai/jslite#readme",
  "publishConfig": {
    "access": "public"
  }
}
